{
  "auth": {
    "mode": "oauth",
    "issuer": "http://localhost:9080",
    "clientId": "lumen-admin-ui",
    "scopes": ["openid", "profile", "email", "admin"]
  },
  "modules": {
    "gateway": {
      "enabled": true,
      "baseUrl": "http://localhost:18080"
    },
    "oauth": {
      "enabled": true,
      "baseUrl": "http://localhost:9080"
    },
    "mcp": {
      "enabled": true,
      "baseUrl": "http://localhost:9280"
    },
    "monitoring": {
      "enabled": true,
      "baseUrl": "http://localhost:3000",
      "orgId": 1,
      "theme": "dark",
      "kiosk": true,
      "dashboards": {
        "gateway": "lumen-gateway"
      }
    }
  },
  "ui": {
    "theme": "system",
    "defaultLanding": "/gateway"
  },
  "features": {
    "oauthApiEnabled": true,
    "mcpApiEnabled": true,
    "dcrEnabled": true,
    "inviteEnabled": true,
    "rbacEnabled": false
  }
}
